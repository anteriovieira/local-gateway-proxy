{
  "manifest_version": 3,
  "name": "Proxy App",
  "version": "1.0.0",
  "description": "API proxy and request interceptor",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/response-capture.ts"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "sidePanel",
    "storage",
    "webRequest",
    "scripting",
    "declarativeNetRequestWithHostAccess",
    "declarativeNetRequestFeedback",
    "activeTab",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/index.ts"
  },
  "side_panel": {
    "default_path": "sidebar/index.html"
  },
  "action": {
    "default_title": "Open Proxy App",
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "48": "public/icons/icon-48.png",
      "128": "public/icons/icon-128.png"
    }
  },
  "icons": {
    "16": "public/icons/icon-16.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  }
}
