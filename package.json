{
  "name": "proxy-app-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:desktop": "turbo dev --filter=@proxy-app/desktop",
    "dev:extension": "turbo dev --filter=@proxy-app/extension",
    "build": "turbo build",
    "build:desktop": "turbo build --filter=@proxy-app/desktop",
    "build:extension": "turbo build --filter=@proxy-app/extension",
    "clean": "turbo clean",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
